/*
 * Process resource labels — adjust for your HPC environment.
 * These labels are referenced by modules via `label 'process_*'`.
 */
process {
    shell        = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = 'terminate'

    withLabel: process_single {
        cpus   = 2
        memory = '4 GB'
    }
    withLabel: process_small {
        cpus   = 4
        memory = '8 GB'
    }
    withLabel: process_medium {
        cpus   = 8
        memory = '16 GB'
    }
    withLabel: process_large {
        cpus   = 16
        memory = '28 GB'
    }
    withLabel: process_high {
        cpus   = 16
        memory = '28 GB'
    }
}
