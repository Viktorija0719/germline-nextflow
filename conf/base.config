/*
 * Process resource labels — tuned for Rudens cluster.
 * Nodes: 24 cores (Intel Xeon E5-2680 v3), 128 GB DDR4 RAM each.
 * Memory-per-core ratio: ~5.3 GB/core.
 * These labels are referenced by modules via `label 'process_*'`.
 */
process {
    shell        = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = 'terminate'

    withLabel: process_single {
        cpus   = 2
        memory = '8 GB'
    }
    withLabel: process_small {
        cpus   = 4
        memory = '16 GB'
    }
    withLabel: process_medium {
        cpus   = 8
        memory = '40 GB'
    }
    withLabel: process_large {
        cpus   = 16
        memory = '80 GB'
    }
    withLabel: process_high {
        cpus   = 16
        memory = '80 GB'
    }
}
