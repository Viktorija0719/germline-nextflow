/*
 * Per-process publishDir paths and ext.args.
 * Keeps nextflow.config and workflow files clean.
 */
process {

    // -------------------------------------------------------
    // Alignment & deduplication
    // -------------------------------------------------------
    withName: 'BWA_MEM' {
        cpus   = 16
        memory = '28 GB'
        scratch = true
    }
    withName: 'BIOBAMBAM_BAMMARKDUPLICATES2' {
        publishDir = [ path: "${params.outdir}/bam", mode: 'copy' ]
        cpus   = 16
        memory = '28 GB'
        ext.args = 'rmdup=1'
    }
    withName: 'SAMTOOLS_INDEX' {
        publishDir = [ path: "${params.outdir}/bam", mode: 'copy' ]
    }
    withName: 'PICARDLIKE_DUPMETRICS' {
        publishDir = [ path: "${params.outdir}/qc/dup_metrics", mode: 'copy' ]
    }

    // -------------------------------------------------------
    // QC
    // -------------------------------------------------------
    withName: 'FASTQC' {
        publishDir = [ path: "${params.outdir}/qc/fastqc", mode: 'copy' ]
    }
    withName: 'SAMTOOLS_IDXSTATS' {
        publishDir = [ path: "${params.outdir}/qc/idxstats", mode: 'copy' ]
    }
    withName: 'QUALIMAP_BAMQC' {
        publishDir = [ path: "${params.outdir}/qc/qualimap", mode: 'copy' ]
    }
    withName: 'VERIFYBAMID_VERIFYBAMID2' {
        publishDir  = [ path: "${params.outdir}/qc/verifybamid2", mode: 'copy' ]
        errorStrategy = 'ignore'
        maxRetries  = 1
    }

    // -------------------------------------------------------
    // Coverage / CNV
    // -------------------------------------------------------
    withName: 'GATK_DEPTHOFCOVERAGE' {
        publishDir    = [ path: "${params.outdir}/cnv/depthofcoverage", mode: 'copy' ]
        errorStrategy = 'ignore'
    }
    withName: 'GATK_ANNOTATEINTERVALS' {
        publishDir = [ path: "${params.outdir}/cnv/xhmm", mode: 'copy' ]
    }
    withName: 'XHMM_PIPELINE' {
        publishDir = [ path: "${params.outdir}/cnv/xhmm", mode: 'copy' ]
        ext.prefix = { params.xhmm_prefix ?: 'DATA' }
    }
    withName: 'EXOMEDEPTH' {
        publishDir  = [ path: "${params.outdir}/cnv/exomedepth", mode: 'copy' ]
        cpus        = 8
        memory      = '16 GB'
        ext.prefix      = { params.exomedepth_prefix     ?: 'exomedepth' }
        ext.include_x   = { params.exomedepth_include_x  ?: true }
        ext.bed_coord   = { params.exomedepth_bed_coord   ?: 'bed0' }
        ext.include_chr = { params.exomedepth_include_chr ?: 'auto' }
        ext.args        = { params.exomedepth_args        ?: '' }
    }

    // -------------------------------------------------------
    // Variant calling
    // -------------------------------------------------------
    withName: 'DEEPVARIANT_RUNDEEPVARIANT' {
        cpus   = 16
        memory = '16 GB'
        ext.args = {
            def model = (params.wes != null)
                ? (params.wes ? 'WES' : 'WGS')
                : params.deepvariant_model_type
            "--model_type=${model} ${params.deepvariant_args}".trim()
        }
    }
    withName: 'GATHER_DEEPVARIANT_VCFS' {
        publishDir = [ path: "${params.outdir}/variants/deepvariant", mode: 'copy' ]
    }
    withName: 'STRELKA_GERMLINE' {
        publishDir = [ path: "${params.outdir}/variants/strelka/raw", mode: 'copy' ]
    }
    withName: 'STRELKA_CHRM_FILTER' {
        publishDir = [ path: "${params.outdir}/variants/strelka/filtered", mode: 'copy' ]
    }
    withName: 'MANTA_GERMLINE' {
        publishDir = [
            path: "${params.outdir}/cnv/manta",
            mode: 'copy',
            saveAs: { filename -> "${task.tag}/${filename}" }
        ]
        errorStrategy = 'ignore'
    }

    // -------------------------------------------------------
    // SVDB annotation
    // -------------------------------------------------------
    withName: 'SVDB_BUILD_MANTA' {
        publishDir = [ path: "${params.outdir}/cnv/svdb/db", mode: 'copy' ]
        ext.prefix = 'manta_cohort'
    }
    withName: 'SVDB_BUILD_XHMM' {
        publishDir = [ path: "${params.outdir}/cnv/svdb/db", mode: 'copy' ]
        ext.prefix = 'xhmm_cohort'
    }
    withName: 'SVDB_BUILD_ED' {
        publishDir = [ path: "${params.outdir}/cnv/svdb/db", mode: 'copy' ]
        ext.prefix = 'exomedepth_cohort'
    }
    withName: 'XCNV2VCF' {
        publishDir = [ path: "${params.outdir}/cnv/xhmm_annotated", mode: 'copy', pattern: '*.xcnv.vcf' ]
    }
    withName: 'EXOMEDEPTH_CNV2VCF' {
        publishDir = [ path: "${params.outdir}/cnv/exomedepth_annotated", mode: 'copy' ]
    }
    withName: 'SVDB_QUERY_MANTA' {
        publishDir = [ path: "${params.outdir}/cnv/manta_svdb_annotated", mode: 'copy' ]
        ext.prefix = { "${meta.id}_svdb" }
    }
    withName: 'SVDB_QUERY_XHMM' {
        publishDir = [ path: "${params.outdir}/cnv/xhmm_svdb_annotated", mode: 'copy' ]
        ext.prefix = { "${meta.id}_svdb" }
    }
    withName: 'SVDB_QUERY_ED' {
        publishDir = [ path: "${params.outdir}/cnv/exomedepth_svdb_annotated", mode: 'copy' ]
        ext.prefix = { "${meta.id}_svdb" }
    }

    withName: 'FILTER_COMMON_CNVS_ED' {
        publishDir = [ path: "${params.outdir}/cnv/filtered", mode: 'copy' ]
        ext.prefix = { "${meta.id}.frq_filt_ed" }
        // ext.frq_threshold = '0.1'   // default: 0.1
    }
    withName: 'FILTER_COMMON_CNVS_XHMM' {
        publishDir = [ path: "${params.outdir}/cnv/filtered", mode: 'copy' ]
        ext.prefix = { "${meta.id}.frq_filt_xhmm" }
        // ext.frq_threshold = '0.1'   // default: 0.1
    }
    withName: 'FILTER_COMMON_CNVS_MANTA' {
        publishDir = [ path: "${params.outdir}/cnv/filtered", mode: 'copy' ]
        ext.prefix       = { "${meta.id}.frq_filt_manta" }
        ext.manta_filter = true
        // ext.frq_threshold = '0.1'   // default: 0.1
        // ext.svlen_max     = '1000000' // default: 1000000
    }

    withName: 'ANNOTSV_ED' {
        publishDir = [ path: "${params.outdir}/cnv/exomedepth_annotsv", mode: 'copy' ]
        ext.prefix = { "${meta.id}_annotsv" }
        // ext.args = '-svtBEDcol 4'  // uncomment if input is BED rather than VCF
    }
    withName: 'ANNOTSV_XHMM' {
        publishDir = [ path: "${params.outdir}/cnv/xhmm_annotsv", mode: 'copy' ]
        ext.prefix = { "${meta.id}_annotsv" }
    }
    withName: 'ANNOTSV_MANTA' {
        publishDir = [ path: "${params.outdir}/cnv/manta_annotsv", mode: 'copy' ]
        ext.prefix = { "${meta.id}_annotsv" }
    }

    withName: 'KNOTANNOTSV_ED' {
        publishDir = [ path: "${params.outdir}/cnv/exomedepth_knotannotsv", mode: 'copy' ]
        ext.prefix = { "${meta.id}_knot" }
    }
    withName: 'KNOTANNOTSV_XHMM' {
        publishDir = [ path: "${params.outdir}/cnv/xhmm_knotannotsv", mode: 'copy' ]
        ext.prefix = { "${meta.id}_knot" }
    }
    withName: 'KNOTANNOTSV_MANTA' {
        publishDir = [ path: "${params.outdir}/cnv/manta_knotannotsv", mode: 'copy' ]
        ext.prefix = { "${meta.id}_knot" }
    }

    // -------------------------------------------------------
    // VCF merging / normalisation
    // -------------------------------------------------------
    withName: 'BCFTOOLS_CONCAT_VCF' {
        publishDir = [ path: "${params.outdir}/variants/combined/raw", mode: 'copy' ]
    }
    withName: 'BCFTOOLS_NORM_COMBINED' {
        publishDir = [ path: "${params.outdir}/variants/combined/normalized", mode: 'copy' ]
    }
    withName: 'BCFTOOLS_NORM_DVONLY' {
        publishDir = [ path: "${params.outdir}/variants/deepvariant_normalized", mode: 'copy' ]
    }
}
