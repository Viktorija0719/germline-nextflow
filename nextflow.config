nextflow.enable.dsl = 2

manifest {
    name        = 'germline-nextflow'
    description = 'Lane-aware germline pipeline: alignment, QC, CNV (ExomeDepth/XHMM), SNV/SV (DeepVariant/Strelka2/Manta)'
    mainScript  = 'main.nf'
    version     = '2.0.0'
    // paramsFile not supported until NF ≥ 25.10 — use: nextflow run main.nf -params-file params.yaml
}

// ---------------------------------------------------------------------------
// Parameters
// ---------------------------------------------------------------------------
params {

    // --- Reference genome (iGenomes) ---
    genome          = null
    igenomes_base   = 's3://ngi-igenomes/igenomes/'
    igenomes_ignore = false

    // --- I/O ---
    input  = "${projectDir}/samplesheet.csv"
    outdir = "${projectDir}/results"

    // --- BAM reuse strategy ---
    use_existing_bams    = true
    existing_bam_dir     = "${params.outdir}/bam"
    existing_bams_strict = false   // true → fail when any BAM/BAI missing; false → fall back to alignment

    // --- Duplicate metrics conversion ---
    picardlike_enable = true

    // --- BED / intervals ---
    intervals                     = null
    no_intervals                  = false
    nucleotides_per_second        = 10000000
    chunk_target_seconds          = 600
    chunk_longest_factor          = 1.05
    genome_window_bp              = 20000000   // 20 Mb windows when building intervals from FAI
    build_intervals_exclude_regex = ''         // e.g. '^(GL|KI|chrUn|hs37d5)'
    bed_validate_strict           = true
    bed_contig_autofix            = true
    bed_autocorrect_chr_prefix    = true   // legacy alias for bed_contig_autofix
    bed_cache_dir                 = null

    // --- Role-specific BEDs (fallback chain: specific > master_bed > genome.bed) ---
    master_bed           = null
    qualimap_feature_bed = null
    coverage_target_bed  = null
    variant_target_bed   = null
    xhmm_intervals_bed   = null

    // --- Assay type shorthand ---
    // wes = true  → deepvariant_model_type auto-set to 'WES'
    // wes = false → deepvariant_model_type auto-set to 'WGS'
    // Leave null to use deepvariant_model_type directly
    wes = null

    // --- DeepVariant resources ---
    par_regions_bed        = "${projectDir}/resources/par_regions.bed"
    deepvariant_gzi_dummy  = "${projectDir}/resources/dummy_fasta.gzi"
    deepvariant_model_type = 'WES'   // overridden by wes=true/false when set
    deepvariant_args       = ''

    // --- QC toggles ---
    fastqc_enable       = true
    idxstats_enable     = true
    qualimap_enable     = true
    verifybamid2_enable = true

    // --- VerifyBamID2 resources ---
    verifybamid2_ud         = "${projectDir}/resources/verifybamid2/1000g.phase3.100k.b38.vcf.gz.dat.UD"
    verifybamid2_mu         = "${projectDir}/resources/verifybamid2/1000g.phase3.100k.b38.vcf.gz.dat.mu"
    verifybamid2_bed        = "${projectDir}/resources/verifybamid2/1000g.phase3.100k.b38.vcf.gz.dat.bed"
    verifybamid2_dummy_refvcf = "${projectDir}/resources/verifybamid2/dummy.txt"

    // --- Coverage / CNV toggles ---
    depthofcoverage_enable = true
    gatk_gene_list         = "${projectDir}/resources/refGene.hg38.refseq"

    xhmm_enable             = true
    xhmm_prefix             = 'DATA'
    xhmm_param_file         = "${projectDir}/resources/xhmm/params.txt"
    xhmm_extreme_gc_targets = null

    exomedepth_enable      = true
    exomedepth_prefix      = 'exomedepth'
    exomedepth_target_bed  = null
    exomedepth_include_x   = true
    exomedepth_bed_coord   = 'bed0'    // '0-based BED' coords; use 'one' for 1-based
    exomedepth_include_chr = 'auto'    // 'auto' | 'TRUE' | 'FALSE'
    exomedepth_args        = ''

    // --- Variant calling toggles ---
    deepvariant_enable        = true
    strelka_enable            = true
    manta_enable              = true
    manta_config              = "${projectDir}/resources/manta/manta_germline.ini"

    combine_dv_strelka_enable   = false
    norm_combined_enable        = true
    norm_dv_only_enable         = true
    strict_variant_requirements = true
}

// ---------------------------------------------------------------------------
// Config includes
// ---------------------------------------------------------------------------
if (!params.igenomes_ignore) {
    includeConfig 'conf/igenomes.config'
}
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ---------------------------------------------------------------------------
// AWS (anonymous access for public iGenomes bucket)
// ---------------------------------------------------------------------------
aws {
    client { anonymous = true }
}

// ---------------------------------------------------------------------------
// Execution profiles
// ---------------------------------------------------------------------------
profiles {

    standard {
        process.executor    = 'local'
        docker.enabled      = false
        singularity.enabled = false
    }

    docker {
        process.executor  = 'local'
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        docker.registry   = 'quay.io'
    }

    singularity {
        process.executor = 'local'
        docker.enabled   = false
        wave.enabled     = false
        singularity {
            enabled     = true
            autoMounts  = true
            pullTimeout = '60m'
        }
    }

    slurm {
        process.executor = 'slurm'
        docker.enabled   = false
        singularity {
            enabled    = true
            autoMounts = true
        }
    }
}
